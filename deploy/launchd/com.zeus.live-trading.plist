<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Created: 2026-07-08 (R0-f plist secrets migration prep; this daemon's
  plist was live-only until now — see docs/rebuild/r0f_plist_migration.md).
  Authority basis: docs/rebuild/EXECUTION_MASTER_2026-07-07.md §E R0-f,
  §C constraint 8 (secrets never enter source/reports/git).

  ARTIFACT ONLY. This is the live-trading money-path daemon (src.main).
  It is the primary order-submission process; treat any change here as
  money-path.

  CREDENTIALS - DO NOT COMMIT REAL SECRETS. macOS launchd has no
  EnvironmentFile directive, so secrets cannot live as plain
  EnvironmentVariables entries without landing in this committed file.
  Instead ProgramArguments wraps the real command in
  `/bin/bash -lc 'set -a; source $HOME/.zeus/secrets.env; set +a; exec ...'`
  so POLYMARKET_API_KEY / POLYMARKET_API_SECRET / POLYMARKET_API_PASSPHRASE
  / WU_API_KEY are sourced at process start from a chmod-600 file OUTSIDE
  the repo ($HOME/.zeus/secrets.env), never written here.

  INSTALL (operator):
    1. Populate $HOME/.zeus/secrets.env (chmod 600) with:
         export POLYMARKET_API_KEY=...
         export POLYMARKET_API_SECRET=...
         export POLYMARKET_API_PASSPHRASE=...
         export WU_API_KEY=...
       (scripts/ops/migrate_plist_secrets.sh --apply extracts these from the
       currently-installed live plist automatically — see
       docs/rebuild/r0f_plist_migration.md for the full sequence.)
    2. cp deploy/launchd/com.zeus.live-trading.plist ~/Library/LaunchAgents/
    3. Restart via the mesh-coherent path, never a bare kickstart:
         python3 scripts/deploy_live.py restart all
-->
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>POLYMARKET_CLOB_V2_SIGNATURE_TYPE</key>
		<string>2</string>
		<key>PYTHONPATH</key>
		<string>/Users/leofitz/zeus</string>
		<key>PYTHONSAFEPATH</key>
		<string>1</string>
		<key>ZEUS_CLOB_FACT_CACHE_TTL_SECONDS</key>
		<string>0</string>
		<key>ZEUS_DB_BUSY_TIMEOUT_MS</key>
		<string>30000</string>
		<key>ZEUS_ENTRY_FORECAST_READINESS_WRITER</key>
		<string>1</string>
		<key>ZEUS_LIVE_DERIVED_WRITE_BUSY_TIMEOUT_MS</key>
		<string>1000</string>
		<key>ZEUS_MARKET_DISCOVERY_SNAPSHOT_BUDGET_SECONDS</key>
		<string>600</string>
		<key>ZEUS_MARKET_DISCOVERY_SNAPSHOT_MAX_OUTCOMES</key>
		<string>22</string>
		<key>ZEUS_MODE</key>
		<string>live</string>
		<key>ZEUS_PRIMARY_ROOT</key>
		<string>/Users/leofitz/zeus</string>
		<key>ZEUS_PUSD_FX_CLASSIFIED</key>
		<string>FX_LINE_ITEM</string>
		<key>ZEUS_REACTOR_CLAIM_BUSY_TIMEOUT_MS</key>
		<string>3000</string>
		<key>ZEUS_REACTOR_REFRESH_BUDGET_SECONDS</key>
		<string>19.0</string>
		<key>ZEUS_TIGGE_INGEST_ENABLED</key>
		<string>1</string>
		<key>ZEUS_USER_CHANNEL_WS_AUTO_DERIVE</key>
		<string>1</string>
		<key>ZEUS_VENUE_HEARTBEAT_MODE</key>
		<string>external</string>
	</dict>
	<key>KeepAlive</key>
	<true/>
	<key>Label</key>
	<string>com.zeus.live-trading</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-lc</string>
		<string>set -a; source $HOME/.zeus/secrets.env; set +a; exec /Users/leofitz/zeus/.venv/bin/python -m src.main</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>/Users/leofitz/zeus/logs/zeus-live.err</string>
	<key>StandardOutPath</key>
	<string>/Users/leofitz/zeus/logs/zeus-live.log</string>
	<key>ThrottleInterval</key>
	<integer>30</integer>
	<key>WorkingDirectory</key>
	<string>/Users/leofitz/zeus</string>
</dict>
</plist>
