<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Created: 2026-07-08 (R0-f plist secrets migration prep; this daemon's
  plist was live-only until now — see docs/rebuild/r0f_plist_migration.md).
  Authority basis: docs/rebuild/EXECUTION_MASTER_2026-07-07.md §E R0-f,
  §C constraint 8 (secrets never enter source/reports/git).

  ARTIFACT ONLY. Ingest daemon (src.ingest_main).

  CREDENTIALS - DO NOT COMMIT REAL SECRETS. macOS launchd has no
  EnvironmentFile directive, so WU_API_KEY cannot live as a plain
  EnvironmentVariables entry without landing in this committed file.
  Instead ProgramArguments wraps the real command in
  `/bin/bash -lc 'set -a; source $HOME/.zeus/secrets.env; set +a; exec ...'`
  so WU_API_KEY is sourced at process start from a chmod-600 file OUTSIDE
  the repo ($HOME/.zeus/secrets.env), never written here.

  INSTALL (operator):
    1. Populate $HOME/.zeus/secrets.env (chmod 600) with:
         export WU_API_KEY=...
       (scripts/ops/migrate_plist_secrets.sh --apply extracts this from the
       currently-installed live plist automatically — see
       docs/rebuild/r0f_plist_migration.md for the full sequence.)
    2. cp deploy/launchd/com.zeus.data-ingest.plist ~/Library/LaunchAgents/
    3. Restart via the mesh-coherent path, never a bare kickstart:
         python3 scripts/deploy_live.py restart all
-->
<plist version="1.0">
<dict>
	<key>EnvironmentVariables</key>
	<dict>
		<key>ECMWF_OPEN_DATA_BASE</key>
		<string>https://data.ecmwf.int/forecasts</string>
		<key>PYTHONPATH</key>
		<string>/Users/leofitz/zeus</string>
		<key>PYTHONSAFEPATH</key>
		<string>1</string>
		<key>ZEUS_FORECAST_LIVE_OWNER</key>
		<string>forecast_live</string>
		<key>ZEUS_HARVESTER_LIVE_ENABLED</key>
		<string>1</string>
		<key>ZEUS_PRIMARY_ROOT</key>
		<string>/Users/leofitz/zeus</string>
		<key>ZEUS_USER_CHANNEL_WS_AUTO_DERIVE</key>
		<string>1</string>
		<key>ZEUS_USER_CHANNEL_WS_ENABLED</key>
		<string>1</string>
	</dict>
	<key>KeepAlive</key>
	<true/>
	<key>Label</key>
	<string>com.zeus.data-ingest</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-lc</string>
		<string>set -a; source $HOME/.zeus/secrets.env; set +a; exec /Users/leofitz/zeus/.venv/bin/python -m src.ingest_main</string>
	</array>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardErrorPath</key>
	<string>/Users/leofitz/zeus/logs/zeus-ingest.err</string>
	<key>StandardOutPath</key>
	<string>/Users/leofitz/zeus/logs/zeus-ingest.log</string>
	<key>ThrottleInterval</key>
	<integer>30</integer>
	<key>WorkingDirectory</key>
	<string>/Users/leofitz/zeus</string>
</dict>
</plist>
