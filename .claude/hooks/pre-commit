#!/usr/bin/env bash
# Created: 2026-05-01
# Last reused/audited: 2026-05-06
# Authority basis: ultrareview25_remediation 2026-05-01 P0-2
#   Phase 3 cutover: delegate to dispatch.py (replaces direct legacy script calls)
#   docs/operations/task_2026-05-06_hook_redesign/PLAN.md §3 Phase 3
#
# git pre-commit orchestrator. Fires on every operator-direct `git commit`
# (defense-in-depth: agent commits are also gated via .claude/settings.json
# PreToolUse hooks).
#
# Both sub-checks are required-to-pass. Either one failing aborts the commit.

set -euo pipefail

REPO_ROOT=$(cd "$(dirname "$0")/../.." && pwd)

# Provide empty JSON payload (git pre-commit has no stdin payload)
PAYLOAD='{"hook_event_name":"PreToolUse","tool_name":"Bash","tool_input":{"command":"git commit"}}' 

STATUS=0

run_required_hook() {
    local hook_id="$1"
    if echo "$PAYLOAD" | python3 "${REPO_ROOT}/.claude/hooks/dispatch.py" "$hook_id"; then
        return 0
    else
        local rc=$?
        if [ "$STATUS" -eq 0 ]; then
            STATUS=$rc
        fi
    fi
    return 0
}

# Step 1: invariant test baseline
run_required_hook invariant_test

# Step 2: secrets scan (gracefully skipped if gitleaks not installed)
run_required_hook secrets_scan

exit $STATUS
